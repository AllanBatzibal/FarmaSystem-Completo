{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FarmaSystem — Iniciar",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/FarmaSystem.API/bin/Debug/net8.0/FarmaSystem.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/FarmaSystem.API",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/login"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
